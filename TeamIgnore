-- TeamIgnoreModule_v2.lua
-- Behavior:
--  - If LocalPlayer.Team is in primary list => add primary list into ignoredTeams
--  - elseif LocalPlayer.Team is in exception list => add exception list into ignoredTeams
--  - returns which list was applied ("primary", "exception", or nil)

local TeamIgnoreModule = {}

-- Separate lists by purpose (same placeId)
TeamIgnoreModule.autoIgnoreByPlace = {
    [92328371535077] = {
        primary = {
            "Mobile Task Force",
            "STF Kappa-16",
            "MTF Eta-10",
            "MTF Beta-7",
            "MTF Nu-7",
            "Dept. of Personnel Integrity",
            "Lambda Team",
            "Ethics Committee",
            "Medical Department",
            "Maintenance Crew",
            "MTF Epsilon-9",
            "Security Department",
            "Internal Security",
            "MTF Alpha-1",
            "Scientific Department",
            "MTF Epsilon-11",
            "Administration",
            "Intelligence Agency"
        },
        exception = {
            "Class-D",
            "Chaos Insurgency"
        }
    }
}

-- Return tables: primary and exception (or empty tables)
function TeamIgnoreModule.getListsForPlace(placeId)
    local entry = TeamIgnoreModule.autoIgnoreByPlace[placeId]
    if not entry then
        return {}, {}
    end
    return entry.primary or {}, entry.exception or {}
end

-- Utility: check membership in a list (array of strings)
local function inList(list, name)
    if not list or not name then return false end
    for _, v in ipairs(list) do
        if v == name then return true end
    end
    return false
end

-- Merge list (array) into ignoredTeams table (sets name -> true)
local function mergeIntoIgnored(ignoredTeams, list)
    if type(ignoredTeams) ~= "table" then return false end
    for _, v in ipairs(list) do
        ignoredTeams[v] = true
    end
    return true
end

-- Main function:
--  - ignoredTeams : table (set-like) to update
-- Returns: "primary" if primary applied, "exception" if exception applied, or nil if nothing applied.
function TeamIgnoreModule.updateIgnoredIfLocalInAuto(ignoredTeams)
    if type(ignoredTeams) ~= "table" then return nil end

    local Players = game:GetService("Players")
    local localPlayer = Players.LocalPlayer
    if not localPlayer then return nil end

    local placeId = game.PlaceId
    local primaryList, exceptionList = TeamIgnoreModule.getListsForPlace(placeId)

    local myTeamName = localPlayer.Team and localPlayer.Team.Name
    if not myTeamName then return nil end

    -- If local is in primary -> apply primary list
    if inList(primaryList, myTeamName) then
        mergeIntoIgnored(ignoredTeams, primaryList)
        return "primary"
    end

    -- Else if local is in exception -> apply exception list
    if inList(exceptionList, myTeamName) then
        mergeIntoIgnored(ignoredTeams, exceptionList)
        return "exception"
    end

    return nil
end

-- Extra helper: force-merge specific list type for a place (no local-team check)
-- listType = "primary" or "exception"
function TeamIgnoreModule.forceMerge(ignoredTeams, placeId, listType)
    if type(ignoredTeams) ~= "table" then return false end
    local entry = TeamIgnoreModule.autoIgnoreByPlace[placeId]
    if not entry then return false end
    local list = (listType == "exception") and entry.exception or entry.primary
    if not list then return false end
    for _, v in ipairs(list) do ignoredTeams[v] = true end
    return true
end

return TeamIgnoreModule
