local TeamIgnoreModule = {}

-- Teams are grouped by faction. If your current team is in a group, 
-- everyone else in that same group is automatically ignored (friendly fire disabled).
TeamIgnoreModule.groups = {
    -- Group 1: Foundation Personnel (Administration, MTF, Security, Science)
    {
        "Administration", "Dept. of Personnel Integrity", "Ethics Committee",
        "Facility Guard", "Foundation Personnel", "Head Researcher",
        "Intelligence Agency", "Internal Security", "Janitor", "Lambda Team",
        "Maintenance Crew", "Medical Department", "Mobile Task Force",
        "Mobile Task Forces", "MTF Alpha-1", "MTF Beta-7", "MTF Cadet",
        "MTF Commander", "MTF Epsilon-11", "MTF Epsilon-9", "MTF Eta-10",
        "MTF Lieutenant", "MTF Medic", "MTF Nu-7", "MTF Sniper",
        "MTF Specialist", "Researcher", "Scientist", "Scientific Department",
        "Security Chief", "Security Department", "STF Kappa-16"
    },

    -- Group 2: Chaos Insurgency & Class-D
    {
        "Chaos Insurgency", "CI Alpha", "CI Beta", "CI Delta", "CI Gamma",
        "Class-D", "Class D"
    },

    -- Group 3: SCPs & Serpent's Hand
    {
        "SCP", "Serpents Hand", "SCP-049", "SCP-049-2", "SCP-096", "SCP-106",
        "SCP-1507", "SCP-173", "SCP-1770", "SCP-1770-J", "SCP-247-J",
        "SCP-457", "SCP-610", "SCP-939"
    },

    -- Group 4: Global Occult Coalition & Valravn Corporation
    {
        "Global Occult Coalition", "GOC Captain", "GOC Corporal",
        "GOC Private", "GOC Sapper", "Valravn Corporation"
    },

    -- Group 5: Non-Combatants / Spectators
    {
        "Lobby", "Spectator"
    }
}

-- Main: updates ignoredTeams depending on the local player's current string team.
function TeamIgnoreModule.updateIgnoredIfLocalInAuto(ignoredTeams, myTeamName)
    if type(ignoredTeams) ~= "table" then return nil end
    if not myTeamName or myTeamName == "" then return nil end

    -- Iterate through defined faction groups
    for _, group in ipairs(TeamIgnoreModule.groups) do
        -- table.find is highly optimized in Roblox Luau for searching arrays
        if table.find(group, myTeamName) then
            
            -- Merge the group into the ignoredTeams dictionary
            for _, teamName in ipairs(group) do
                ignoredTeams[teamName] = true
            end
            
            return "applied_group"
        end
    end

    return nil
end

return TeamIgnoreModule
