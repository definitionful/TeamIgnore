local function inList(list, name)
    if not list or not name then return false end
    for _, v in ipairs(list) do
        if v == name then return true end
    end
    return false
end

local function merge(ignoredTeams, list)
    if type(ignoredTeams) ~= "table" then return false end
    for _, v in ipairs(list) do
        ignoredTeams[v] = true
    end
    return true
end

-- Main: updates ignoredTeams depending on the local player's current team.
function TeamIgnoreModule.updateIgnoredIfLocalInAuto(ignoredTeams)
    if type(ignoredTeams) ~= "table" then return nil end

    local Players = game:GetService("Players")
    local lp = Players.LocalPlayer
    if not lp then return nil end

    local placeEntry = TeamIgnoreModule.byPlace[game.PlaceId]
    if not placeEntry or not placeEntry.groups then return nil end

    local myTeamName = lp.Team and lp.Team.Name
    if not myTeamName then return nil end

    -- Iterate through defined groups for this place
    for _, group in ipairs(placeEntry.groups) do
        if inList(group, myTeamName) then
            merge(ignoredTeams, group)
            return "applied_group"
        end
    end

    return nil
end

return TeamIgnoreModule
